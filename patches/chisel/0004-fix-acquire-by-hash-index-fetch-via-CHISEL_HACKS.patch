From 713c2a262882bcac18ef48cdf8edd1e4afbeb688 Mon Sep 17 00:00:00 2001
From: lczyk <marcin.konowalczyk@canonical.com>
Date: Mon, 1 Jun 2026 21:38:54 +0100
Subject: [PATCH] fix: acquire-by-hash index fetch via CHISEL_HACKS

when CHISEL_HACKS is set and the archive advertises Acquire-By-Hash: yes,
fetch Packages.gz via the content-addressed by-hash URL before falling
back to the canonical named path. avoids intermittent digest-mismatch
errors during mid-publication archive updates where the canonical path
briefly serves stale content while InRelease already reflects new digests.
---
 internal/archive/archive.go                 |  41 +++++++-
 internal/archive/archive_test.go            | 101 ++++++++++++++++++++
 internal/archive/testarchive/testarchive.go |  33 ++++---
 3 files changed, 160 insertions(+), 15 deletions(-)

diff --git a/internal/archive/archive.go b/internal/archive/archive.go
index e24a9c2..6c9c62f 100644
--- a/internal/archive/archive.go
+++ b/internal/archive/archive.go
@@ -2,10 +2,13 @@ package archive
 
 import (
 	"compress/gzip"
+	"errors"
 	"fmt"
 	"io"
 	"net/http"
 	"net/url"
+	"os"
+	"path"
 	"slices"
 	"strings"
 	"time"
@@ -65,6 +68,7 @@ type fetchFlags uint
 
 const (
 	fetchBulk    fetchFlags = 1 << iota
+	fetchGzip
 	fetchDefault fetchFlags = 0
 )
 
@@ -80,6 +84,9 @@ var bulkClient = &http.Client{
 
 var bulkDo = bulkClient.Do
 
+// errArchiveNotFound is returned by fetch when the server responds with 404.
+var errArchiveNotFound = errors.New("cannot find archive data")
+
 type ubuntuArchive struct {
 	options Options
 	indexes []*ubuntuIndex
@@ -334,10 +341,31 @@ func (index *ubuntuIndex) fetchIndex() error {
 	}
 
 	logf("Fetching index for %s %s %s %s component...", index.displayName(), index.version, index.suite, index.component)
-	reader, err := index.fetch(index.distPath(packagesPath+".gz"), digest, fetchBulk)
+
+	gzPackagesPath := packagesPath + ".gz"
+	candidates := []string{index.distPath(gzPackagesPath)}
+	// NOTE: CHISEL_HACKS enables Acquire-By-Hash to avoid digest mismatches
+	// during mid-publication archive updates, where the canonical path may
+	// briefly serve stale content while InRelease already reflects new digests.
+	if os.Getenv("CHISEL_HACKS") != "" && index.release.Get("Acquire-By-Hash") == "yes" {
+		gzDigest, _, _ := control.ParsePathInfo(digests, gzPackagesPath)
+		if gzDigest != "" {
+			candidates = append([]string{byHashPath(index.distPath(gzPackagesPath), gzDigest)}, candidates...)
+		}
+	}
+
+	var reader io.ReadSeekCloser
+	var err error
+	for _, candidate := range candidates {
+		reader, err = index.fetch(candidate, digest, fetchBulk|fetchGzip)
+		if err == nil || !errors.Is(err, errArchiveNotFound) {
+			break
+		}
+	}
 	if err != nil {
 		return err
 	}
+
 	ctrl, err := control.ParseReader("Package", reader)
 	if err != nil {
 		return fmt.Errorf("parsing archive Package file: %v", err)
@@ -347,6 +375,13 @@ func (index *ubuntuIndex) fetchIndex() error {
 	return nil
 }
 
+// byHashPath transforms a dist-relative path like
+// "dists/jammy/main/binary-amd64/Packages.gz" into a by-hash URL
+// "dists/jammy/main/binary-amd64/by-hash/SHA256/<digest>".
+func byHashPath(p, digest string) string {
+	return path.Join(path.Dir(p), "by-hash", "SHA256", digest)
+}
+
 // supportsArch returns true if the Architectures field in the index release
 // contains "arch". Per the Debian wiki [1], index release files should list the
 // supported architectures in the "Architectures" field.
@@ -410,13 +445,13 @@ func (index *ubuntuIndex) fetch(path, digest string, flags fetchFlags) (io.ReadS
 	case 401:
 		return nil, fmt.Errorf("cannot fetch from %q: unauthorized", index.label)
 	case 404:
-		return nil, fmt.Errorf("cannot find archive data")
+		return nil, errArchiveNotFound
 	default:
 		return nil, fmt.Errorf("error from archive: %v", resp.Status)
 	}
 
 	body := resp.Body
-	if strings.HasSuffix(path, ".gz") {
+	if flags&fetchGzip != 0 || strings.HasSuffix(path, ".gz") {
 		reader, err := gzip.NewReader(body)
 		if err != nil {
 			return nil, fmt.Errorf("cannot decompress data: %v", err)
diff --git a/internal/archive/archive_test.go b/internal/archive/archive_test.go
index 8ca840e..14d332e 100644
--- a/internal/archive/archive_test.go
+++ b/internal/archive/archive_test.go
@@ -617,6 +617,107 @@ func (s *httpSuite) TestPackageInfo(c *C) {
 	}
 }
 
+func (s *httpSuite) TestAcquireByHash(c *C) {
+	restoreEnv := fakeEnv("CHISEL_HACKS", "1")
+	defer restoreEnv()
+
+	s.prepareArchiveAdjustRelease("jammy", "22.04", "amd64", []string{"main"}, func(r *testarchive.Release) {
+		r.AcquireByHash = true
+	})
+
+	options := archive.Options{
+		Label:      "ubuntu",
+		Version:    "22.04",
+		Arch:       "amd64",
+		Suites:     []string{"jammy"},
+		Components: []string{"main"},
+		CacheDir:   c.MkDir(),
+		PubKeys:    []*packet.PublicKey{s.pubKey},
+	}
+	_, err := archive.Open(&options)
+	c.Assert(err, IsNil)
+
+	var byHashReqs []*http.Request
+	for _, req := range s.requests {
+		if strings.Contains(req.URL.Path, "by-hash") {
+			byHashReqs = append(byHashReqs, req)
+		}
+	}
+	c.Assert(byHashReqs, HasLen, 1)
+	c.Assert(byHashReqs[0].URL.Path, Matches, `.*/by-hash/SHA256/[0-9a-f]{64}`)
+}
+
+func (s *httpSuite) TestAcquireByHashFallback(c *C) {
+	restoreEnv := fakeEnv("CHISEL_HACKS", "1")
+	defer restoreEnv()
+
+	s.prepareArchiveAdjustRelease("jammy", "22.04", "amd64", []string{"main"}, func(r *testarchive.Release) {
+		r.AcquireByHash = true
+	})
+
+	// Replace FakeDo to return 404 for by-hash URLs, canonical path succeeds normally.
+	var requests []*http.Request
+	s.restore()
+	s.restore = archive.FakeDo(func(req *http.Request) (*http.Response, error) {
+		requests = append(requests, req)
+		if strings.Contains(req.URL.Path, "by-hash") {
+			return &http.Response{
+				Body:       io.NopCloser(strings.NewReader("")),
+				Header:     http.Header{},
+				StatusCode: 404,
+			}, nil
+		}
+		return s.Do(req)
+	})
+
+	options := archive.Options{
+		Label:      "ubuntu",
+		Version:    "22.04",
+		Arch:       "amd64",
+		Suites:     []string{"jammy"},
+		Components: []string{"main"},
+		CacheDir:   c.MkDir(),
+		PubKeys:    []*packet.PublicKey{s.pubKey},
+	}
+	_, err := archive.Open(&options)
+	c.Assert(err, IsNil)
+
+	var sawByHash, sawCanon bool
+	for _, req := range requests {
+		if strings.Contains(req.URL.Path, "by-hash") {
+			sawByHash = true
+		} else if strings.Contains(req.URL.Path, "Packages.gz") {
+			c.Assert(sawByHash, Equals, true, Commentf("canonical Packages.gz fetched before by-hash attempt"))
+			sawCanon = true
+		}
+	}
+	c.Assert(sawByHash, Equals, true)
+	c.Assert(sawCanon, Equals, true)
+}
+
+func (s *httpSuite) TestNoAcquireByHashWithoutChiselHacks(c *C) {
+	// CHISEL_HACKS unset -- by-hash must not be used even if archive advertises it.
+	s.prepareArchiveAdjustRelease("jammy", "22.04", "amd64", []string{"main"}, func(r *testarchive.Release) {
+		r.AcquireByHash = true
+	})
+
+	options := archive.Options{
+		Label:      "ubuntu",
+		Version:    "22.04",
+		Arch:       "amd64",
+		Suites:     []string{"jammy"},
+		Components: []string{"main"},
+		CacheDir:   c.MkDir(),
+		PubKeys:    []*packet.PublicKey{s.pubKey},
+	}
+	_, err := archive.Open(&options)
+	c.Assert(err, IsNil)
+
+	for _, req := range s.requests {
+		c.Assert(req.URL.Path, Not(Matches), `.*/by-hash/.*`)
+	}
+}
+
 func read(r io.Reader) string {
 	data, err := io.ReadAll(r)
 	if err != nil {
