 func (r *Release) Walk(f func(Item) error) error {
@@ -127,7 +128,11 @@ func (r *Release) Content() []byte {
 		content := item.Content()
 		digests.WriteString(fmt.Sprintf(" %s  %d  %s\n", makeSha256(content), len(content), item.Path()))
 	}
-	content := fmt.Sprintf(string(testutil.Reindent(`
+	acquireByHash := ""
+	if r.AcquireByHash {
+		acquireByHash = "Acquire-By-Hash: yes\n"
+	}
+	header := fmt.Sprintf(string(testutil.Reindent(`
 		Origin: Ubuntu
 		Label: %s
 		Suite: %s
@@ -137,9 +142,8 @@ func (r *Release) Content() []byte {
 		Architectures: amd64 arm64 armhf i386 ppc64el riscv64 s390x
 		Components: main restricted universe multiverse
 		Description: Ubuntu %s
-		SHA256:
-		%s
-	`)), r.Label, r.Suite, r.Version, r.Version, digests.String())
+	`)), r.Label, r.Suite, r.Version, r.Version)
+	content := strings.TrimRight(header, " \t\n") + "\n" + acquireByHash + "SHA256:\n" + digests.String() + "\n"
 
 	var buf bytes.Buffer
 	writer, err := clearsign.Encode(&buf, r.PrivKey, nil)
@@ -160,12 +164,17 @@ func (r *Release) Content() []byte {
 func (r *Release) Render(prefix string, content map[string][]byte) error {
 	return r.Walk(func(item Item) error {
 		itemPath := item.Path()
+		itemContent := item.Content()
 		if strings.HasPrefix(itemPath, "pool/") {
-			itemPath = path.Join(prefix, itemPath)
+			content[path.Join(prefix, itemPath)] = itemContent
 		} else {
-			itemPath = path.Join(prefix, "dists", r.Suite, itemPath)
+			content[path.Join(prefix, "dists", r.Suite, itemPath)] = itemContent
+			if r.AcquireByHash && path.Dir(itemPath) != "." {
+				dir := path.Dir(itemPath)
+				digest := makeSha256(itemContent)
+				content[path.Join(prefix, "dists", r.Suite, dir, "by-hash", "SHA256", digest)] = itemContent
+			}
 		}
-		content[itemPath] = item.Content()
 		return nil
 	})
 }
